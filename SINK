def _init_weights(n_in, n_out):
    scale = math.sqrt(2.0 / max(1, n_in))
    w = [[(random.random()*2-1) * scale for _ in range(n_out)] for _ in range(n_in)]
    b = [0.0 for _ in range(n_out)]
    return w, b

def _copy_weights(w, b):
    return [row[:] for row in w], b[:]

def _forward(w1, b1, w2, b2, x, h_out=None, q_out=None):
    """前向傳播；★ v5.1.3 in-place 寫入 buffer，避免 alloc"""
    if h_out is None: h_out = _h_buf
    if q_out is None: q_out = _q_buf
    for i in range(N_HIDDEN):
        s = b1[i]
        for j in range(N_INPUT):
            s += x[j] * w1[j][i]
        h_out[i] = s if s > 0 else 0.0
    for i in range(N_ACTIONS):
        s = b2[i]
        for j in range(N_HIDDEN):
            s += h_out[j] * w2[j][i]
        q_out[i] = s
    return h_out, q_out

def _to_state(nid, hop_count=1, voi_state="S0"):
    """★ v5.2: state[5] 從 power_budget 換成 voi_urgency
    這樣 DQN 可以學到「VoI=S2 時要不要中繼」這類有意義的關聯"""
    s = node_stats.get(nid, {})
    rssi_val = s.get("rssi", -120)
    rssi_norm = _clip((rssi_val + 120) / 100.0, 0.0, 1.0)
    hop_norm  = _clip(hop_count / 3.0, 0.0, 1.0)
    r = _routing.get(nid, {})
    risk = r.get("risk", 0.0)
    sr   = s.get("success_rate", 0.5)
    eps  = epsilon
    voi_u = VOI_URGENCY.get(voi_state, 0.0)
    return [rssi_norm, hop_norm, risk, sr, eps, voi_u]

def _action_to_decision(nid, action):
    """★ v5.2: 動作從 (link_class × relay_idx) 簡化為 {DIRECT, RELAY}
    relay 的具體鄰居由 AODV 路由表挑（_routing[nid]['nh']）"""
    if action == ACTION_DIRECT:
        return "DIRECT", None
    # RELAY: 由 AODV 表查最佳下一跳
    r = _routing.get(nid, {})
    return "RELAY", r.get("nh", None)

def choose_action(nid, hop_count=1, voi_state="S0"):
    """★ v5.2.1: _action_count 拆成 recommended (DQN自己想做) 和 actual (leaf真做了)
    這個函式只更新 recommended"""
    global epsilon, _avg_q_ema

    if EXPERIMENT_TAG == "ALWAYS_LORA" or EXPERIMENT_TAG == "ALWAYS_WIFI":
        a = ACTION_DIRECT
        _action_count_recommended[a] += 1
        return a
    if EXPERIMENT_TAG == "PERIODIC":
        a = ACTION_DIRECT
        _action_count_recommended[a] += 1
        return a

    st = _to_state(nid, hop_count, voi_state)
    if random.random() < epsilon:
        a = random.randint(0, N_ACTIONS-1)
    else:
        _forward(_w1, _b1, _w2, _b2, st, _h_buf, _q_buf)
        best = 0; bv = _q_buf[0]
        for i in range(1, N_ACTIONS):
            if _q_buf[i] > bv: bv = _q_buf[i]; best = i
        a = best
        _avg_q_ema = 0.95*_avg_q_ema + 0.05*bv
    _action_count_recommended[a] += 1
    epsilon = max(EPSILON_MIN, epsilon * EPSILON_DECAY)
    return a

# ── PER ──

def _per_push(s, a, r, sn, done, init_pri=None):
    global _per_idx
    p = init_pri
    if p is None:
        p = (max(_per_pri) if _per_pri else 1.0)
    if len(_per_s) < REPLAY_BUF_SIZE:
        _per_s.append(s); _per_a.append(a); _per_r.append(r)
        _per_sn.append(sn); _per_done.append(done); _per_pri.append(p)
    else:
        i = _per_idx % REPLAY_BUF_SIZE
        _per_s[i]=s; _per_a[i]=a; _per_r[i]=r
        _per_sn[i]=sn; _per_done[i]=done; _per_pri[i]=p
    _per_idx += 1

def _per_sample(k):
    n = len(_per_s)
    if n == 0: return [], []
    probs = [pp ** PER_ALPHA for pp in _per_pri]
    tot = sum(probs)
    if tot <= 0:
        probs = [1.0]*n; tot = float(n)
    frac = min(1.0, _frames / PER_BETA_FRAMES)
    beta = PER_BETA_START + (PER_BETA_END - PER_BETA_START) * frac
    idxs = []; ws = []; max_w = 0.0
    for _ in range(k):
        r = random.random() * tot
        acc = 0.0; pick = 0
        for i in range(n):
            acc += probs[i]
            if acc >= r:
                pick = i; break
        idxs.append(pick)
        pr = probs[pick] / tot
        w  = (n * pr) ** (-beta)
        if w > max_w: max_w = w
        ws.append(w)
    if max_w > 0:
        ws = [w / max_w for w in ws]
    return idxs, ws

def _per_update(idx, td_err):
    _per_pri[idx] = abs(td_err) + PER_EPS

def enqueue_experience(nid, action, reward, next_nid, hop_count, done=False, voi_state="S0"):
    """★ v5.2: 加入 voi_state 維度；硬上限 PENDING_EXP_HARD_CAP 防爆"""
    s  = _to_state(nid, hop_count, voi_state)
    sn = _to_state(next_nid if next_nid in _known_nodes else nid,
                   max(0, hop_count-1) if next_nid in _known_nodes else 0,
                   voi_state)
    _pending_exp.append((s, action, reward, sn, done))
    # ★ ring buffer：超過硬上限丟最舊的
    while len(_pending_exp) > PENDING_EXP_HARD_CAP:
        _pending_exp.pop(0)

def _train_dqn_batch(n_batches=1):
    """★ v5.2: 一次訓練 n_batches 個 mini-batch（取代原本每幀訓練）
    主迴圈每 5 分鐘呼叫一次，n_batches=TRAIN_BATCHES_PER_RUN"""
    global _dqn_loss_ema, _tw1, _tb1, _tw2, _tb2, _steps
    if len(_per_s) < BATCH_SIZE:
        return 0
    free = gc.mem_free()
    if free < 80000:   # ★ v5.2: 訓練門檻提高到 80K，安全餘裕更大
        print("[DQN] skip train: free_ram=%d < 80K" % free)
        gc.collect()
        return 0

    batches_done = 0
    for _b in range(n_batches):
        if gc.mem_free() < 70000:
            print("[DQN] mid-train RAM low, stop early")
            break
        idxs, isw = _per_sample(BATCH_SIZE)
        loss_sum = 0.0
        for bi, idx in enumerate(idxs):
            s      = _per_s[idx]
            a      = _per_a[idx]
            r      = _per_r[idx]
            sn     = _per_sn[idx]
            done   = _per_done[idx]
            w_is   = isw[bi]

            # Double-DQN
            _forward(_w1, _b1, _w2, _b2, sn, _h_buf, _q_buf)
            a_star = 0; bv = _q_buf[0]
            for i in range(1, N_ACTIONS):
                if _q_buf[i] > bv: bv = _q_buf[i]; a_star = i
            _forward(_tw1, _tb1, _tw2, _tb2, sn, _h_buf2, _q_buf2)
            y = r + (0.0 if done else GAMMA * _q_buf2[a_star])

            _forward(_w1, _b1, _w2, _b2, s, _h_buf, _q_buf)
            td = y - _q_buf[a]
            loss_sum += td * td

            grad_out = -td * w_is
            for j in range(N_HIDDEN):
                _w2[j][a] -= LR * grad_out * _h_buf[j]
            _b2[a] -= LR * grad_out

            for j in range(N_HIDDEN):
                if _h_buf[j] <= 0: continue
                dh = grad_out * _w2[j][a]
                for k in range(N_INPUT):
                    _w1[k][j] -= LR * dh * s[k]
                _b1[j] -= LR * dh

            _per_update(idx, td)

        _dqn_loss_ema = 0.9*_dqn_loss_ema + 0.1*(loss_sum / max(1, len(idxs)))
        batches_done += 1
        _steps += 1
        if _steps % TARGET_UPDATE_STEPS == 0:
            _tw1, _tb1 = _copy_weights(_w1, _b1)
            _tw2, _tb2 = _copy_weights(_w2, _b2)

    gc.collect()
    return batches_done

def update_node_best_decision():
    """★ v5.2: 改為記錄「DIRECT 還是 RELAY 比較好」+ 對應的 transport 建議
    這個建議會放進 ROUTE / QHINT 廣播，leaf 端可參考"""
    for nid in _known_nodes:
        # 對每個可能的 VoI state 算最佳 action
        best_per_voi = {}
        for voi in ("S0", "S1", "S2", "S3"):
            st = _to_state(nid, 1, voi)
            _forward(_w1, _b1, _w2, _b2, st, _h_buf, _q_buf)
            best_a = ACTION_DIRECT
            best_q = _q_buf[ACTION_DIRECT]
            if _q_buf[ACTION_RELAY] > best_q:
                best_a = ACTION_RELAY
                best_q = _q_buf[ACTION_RELAY]
            best_per_voi[voi] = ACTION_LABELS[best_a]
        # 用 transport 替代原本的 best_lc：依 VoI 硬規則 + DQN 的 relay 建議組合
        # 預設用 S0 的決策當「平時」建議
        s0_dec = best_per_voi.get("S0", "DIRECT")
        s2_dec = best_per_voi.get("S2", "DIRECT")
        _per_node_best_decision[nid] = {
            "common": s0_dec,        # 平時建議
            "alert":  s2_dec,        # 緊急時建議
            "transport_common": VOI_TO_TRANSPORT["S0"],   # LORA
            "transport_alert":  VOI_TO_TRANSPORT["S2"],   # WIFI
        }


def _compute_reward(raw_rssi, link_class, success, hop_count, risk, orig_rssi=None, action=None):
    """
    ★ v5.2.1: reward function 精準化
      - 修正 v5.2 的 RELAY 偏差：當 RSSI 很好還選 RELAY → 重懲罰
      - VOI_DRIVEN：能耗 + RSSI 適配 + relay 必要性
      - ALWAYS_* / PERIODIC：只看成功 / 失敗
    """
    lc = LINK_CLASS.get(link_class, LINK_CLASS["B"])

    if EXPERIMENT_TAG in ("ALWAYS_LORA", "ALWAYS_WIFI", "PERIODIC"):
        return 1.0 if success else -1.0

    # === VOI_DRIVEN ===
    if not success:
        # 失敗額外考慮：若選 RELAY 失敗，懲罰重一點（學會「沒事別繞路」）
        return -1.5 if action == ACTION_RELAY else -1.0

    r = 1.0
    r -= lc["power_cost"] * 0.5

    is_relay = (action == ACTION_RELAY) or (hop_count > 1)

    # ★ v5.2.1 核心修正：當 RSSI 已經很好，選 RELAY 是嚴重浪費
    if is_relay:
        if raw_rssi > -60:
            r -= 1.5   # 訊號超好還繞路 → 重罰
        elif raw_rssi > -75:
            r -= 0.8   # 訊號好還繞路 → 中罰
        elif raw_rssi > -90:
            r -= 0.2   # 訊號普通 → 小罰（中性）
        else:
            # 訊號真的差（< -90）才獎勵 RELAY
            r += 0.5
    else:  # DIRECT
        if raw_rssi > -70:
            r += 0.5   # 訊號好直連 → 大獎
        elif raw_rssi > -85:
            r += 0.2   # 訊號普通直連 → 小獎
        elif raw_rssi < -95:
            r -= 0.5   # 訊號真的差還硬直連 → 懲罰

    r -= 0.3 * risk

    # 多跳的 orig_rssi 額外驗證 relay 是否真的有效
    if hop_count > 1 and orig_rssi is not None:
        if orig_rssi < -90:
            r += 0.3   # 原本訊號差，relay 確實救了 → 加分
        elif orig_rssi > -70:
            r -= 0.5   # 原本訊號好，relay 沒必要 → 加重懲罰

    return r

def _expand_relay_payload(pkt):
    """★ v5.6.3: 解壓 relay 內層 payload (t/s/q/n/w/d/r/fb/...) → 標準欄位"""
    if not isinstance(pkt, dict): return pkt
    # 偵測是否為壓縮格式(有 "t" 小寫且無 "T")
    if "t" not in pkt or "T" in pkt:
        return pkt  # 已是標準格式
    expanded = {}
    t_map = {"D":"DATA","A":"ACK","R":"RELAY","M":"MODE"}
    expanded["T"] = t_map.get(pkt.get("t"), "DATA")
    if "s" in pkt: expanded["SRC"] = pkt["s"]
    if "q" in pkt: expanded["SEQ"] = pkt["q"]
    if "n" in pkt: expanded["semantic_state_name"] = pkt["n"]
    if "w" in pkt: expanded["water_level"] = pkt["w"]
    if "d" in pkt: expanded["delta_10m"] = pkt["d"]
    if "r" in pkt: expanded["risk"] = pkt["r"]
    if "a" in pkt: expanded["above_alert_line"] = pkt["a"]
    # ★ v5.6.10: 短欄位名直接保留(不再轉長名)
    if "tl" in pkt: expanded["tl"] = pkt["tl"]
    if "al" in pkt: expanded["al"] = pkt["al"]
    if "E"  in pkt: expanded["E"]  = pkt["E"]
    # FB 欄位:有才加,沒有預設 0
    expanded["FB"]  = pkt.get("fb", 0)
    expanded["FBC"] = pkt.get("fc", 0)
    expanded["FBR"] = pkt.get("fr", 0)
    expanded["FBP"] = pkt.get("fp", 0)
    expanded["FBS"] = pkt.get("fs", 0)
    return expanded

def process_packet(pkt, phy_transport, raw_rssi=-120, via_relay=None, hop_count=1, orig_rssi=None):
    # ★ v5.6.3: 若是壓縮格式,先解壓
    pkt = _expand_relay_payload(pkt)
    src = pkt.get("SRC", 0)
    if not _ensure_node_registered(src): return
    ptype = pkt.get("T","DATA")
    if ptype not in ("DATA","RELAY"): return

    # ★ v5.1.2: LoRa 封包去重
    if phy_transport == "LORA":
        seq = pkt.get("SEQ", 0)
        key = (src, seq)
        now_dd = time.ticks_ms()
        if key in _lora_pkt_dedup and \
           time.ticks_diff(now_dd, _lora_pkt_dedup[key]) < LORA_PKT_DEDUP_MS:
            print("  [LoRa] dup N%d seq=%d, skip" % (src, seq))
            node_stats[src]["dup"] += 1
            # ★ v5.1.3: 重複封包仍然要回 ACK（避免發送端誤判）
            send_lora_ack(src, seq)
            return
        _lora_pkt_dedup[key] = now_dd
        if len(_lora_pkt_dedup) > 200:
            old = sorted(_lora_pkt_dedup.items(), key=lambda x: x[1])
            for k,_ in old[:100]:
                del _lora_pkt_dedup[k]

    # ★ v5.1.3: ACK 第一優先（從 152ms 延遲縮到 < 30ms）
    if phy_transport == "LORA":
        send_lora_ack(src, pkt.get("SEQ"))

    st = node_stats[src]
    st["rx"] += 1
    st["rssi"] = raw_rssi
    st["last_seen"] = time.ticks_ms()
    st["success_rate"] = 0.95*st.get("success_rate",1.0) + 0.05*1.0
    st["last_hop_count"] = hop_count
    st["last_hop_nh"] = via_relay
    if via_relay:
        st["relay_count"] += 1

    wl  = pkt.get("water_level")
    d10 = pkt.get("delta_10m")
    risk = voi_risk(wl, d10)
    _aodv_update_route(src, (via_relay or src), hop_count, raw_rssi, pkt.get("SEQ",0), risk)

    # ★ v5.2: VoI state 給 DQN
    state_str = pkt.get("semantic_state_name","S0")
    # normalize full semantic names (e.g. S2_FLOOD) to short form S2
    voi_short = normalize_voi_short(state_str)

    # ★ v5.2: 用新動作空間 (DIRECT / RELAY)
    action = choose_action(src, hop_count, voi_short)
    decision, suggested_relay = _action_to_decision(src, action)

    # ★ v5.2.1: 根據封包真的怎麼來反推 leaf 實際做了什麼
    #   via_relay 有值 / hop_count > 1 → leaf 走 RELAY
    #   否則 → leaf 走 DIRECT
    actual_action = ACTION_RELAY if (via_relay or hop_count > 1) else ACTION_DIRECT
    _action_count_actual[actual_action] += 1

    # transport 來自 VoI 硬規則，不從 DQN 學
    transport_target = VOI_TO_TRANSPORT.get(voi_short, "LORA")
    # ★ v5.6.9 final: link class 優先用 leaf 帶來的 al(實際使用)
    #   若 leaf 沒帶 al(舊版 leaf 或封包遺漏),退回用 VoI 對應的 lc
    actual_lc_from_leaf = pkt.get("al") or pkt.get("ALC")  # 相容舊版
    if actual_lc_from_leaf and actual_lc_from_leaf in LINK_CLASS:
        link_class = actual_lc_from_leaf
    else:
        link_class = VOI_TO_LINK_CLASS.get(voi_short, "B")
    st["last_link_class"] = link_class
    st["last_decision"]   = decision

    # ★ v5.6.9 final: 能耗 = min(VoI 原應用的 lc 能耗, 實際 link 能耗)
    #   原因(min strategy):
    #     - leaf 因 fallback 換 transport 時(例 S1 WiFi→LoRa),
    #       實際 lc 是 B(100mJ),但 VoI intent 是 C(400mJ)
    #     - 用 min 反映「至少要花的能耗」,不會因為 fallback 反而看起來更省
    #     - 也避免單純報 actual 時讓 fallback 看起來「省能」造成誤解
    #   ENERGY_COST_MJ 已內含 N-TX 加倍:B=100, D=200(=100×2),
    #   故 D 的 200 mJ 已涵蓋 LoRa-2x 的真實能耗,不需再 ×n_tx
    actual_lc = link_class                     # = VOI_TO_LINK_CLASS[voi]
    # ★ v5.6.10: 短欄位優先,長欄位相容
    target_lc = pkt.get("tl") or pkt.get("TLC") or actual_lc
    e_actual  = ENERGY_COST_MJ.get(actual_lc, 100.0)
    e_target  = ENERGY_COST_MJ.get(target_lc, e_actual)
    e_mj      = min(e_actual, e_target)        # min strategy
    is_fb_pkt = pkt.get("FB", 0) == 1 or actual_lc != target_lc
    if actual_action == ACTION_RELAY:
        e_mj *= 1.3   # 多跳 overhead (RELAY 仍維持 1x N-TX,但有 RX+TX 開銷)
    _per_node_energy_mj[src] = _per_node_energy_mj.get(src, 0.0) + e_mj
    _per_node_pkt_count[src][actual_lc] = _per_node_pkt_count[src].get(actual_lc, 0) + 1
    if is_fb_pkt:
        # 標記 fallback 期間的 packet,給統計分析用
        _per_node_pkt_count[src]["_fb_pkts"] = \
            _per_node_pkt_count[src].get("_fb_pkts", 0) + 1

    # ★ v5.5: 從 leaf payload 抽 fallback 統計
    if src in _per_node_fallback:
        fb = _per_node_fallback[src]
        fb["in_fb"]         = pkt.get("FB", 0)
        fb["enter_count"]   = pkt.get("FBC", fb["enter_count"])
        fb["recover_count"] = pkt.get("FBR", fb["recover_count"])
        fb["pending_now"]   = pkt.get("FBP", 0)
        fb["resent_total"]  = pkt.get("FBS", fb["resent_total"])
        fb["last_update"]   = time.ticks_ms()

    # ★ v5.2.1: reward 也要用 actual 而非 DQN 假設的 action
    #           DQN 學 actual 的後果，才會學到「現在直連能成」
    reward = _compute_reward(raw_rssi, link_class, True, hop_count, risk, orig_rssi, action=action)
    enqueue_experience(src, actual_action, reward,
                       (suggested_relay or src), hop_count, voi_state=voi_short)

    # ★ v5.1.3: ACK 已在函數最前面送，這裡不重送

    # ★ v5.1.2: MQTT 封包用 HTML 期望的 key 格式
    state_str = pkt.get("semantic_state_name","S0")
    # state → voi_state 對照
    voi_map = {"S0":"SAFE","S1":"MID","S2":"HIGH","S3":"EVENT"}
    voi_state = voi_map.get(state_str, "SAFE")

    mqtt_publish("sensor/node_%02d/data" % src, {
        "dev_id": "node_%02d" % src,
        "seq": pkt.get("SEQ"),
        "state": state_str,
        "voi_state": voi_state,
        "water_level": wl,
        "water_level_m": wl,             # HTML 用這個
        "delta_10m": d10,
        "rssi": raw_rssi,
        "orig_rssi": orig_rssi,
        "transport": phy_transport,
        "link_class": link_class,
        "target_lc": pkt.get("tl") or pkt.get("TLC") or link_class,   # ★ v5.6.10
        "actual_lc": pkt.get("al") or pkt.get("ALC") or link_class,
        "is_fallback": 1 if (pkt.get("tl") or pkt.get("TLC")) and (pkt.get("tl") or pkt.get("TLC")) != link_class else 0,
        "energy_mj": round(e_mj, 2),               # ★ v5.6.9 本筆封包估算能耗
        "hop_count": hop_count,
        "via_relay": via_relay,
        "relay_path": pkt.get("_relay_path", []),
        "risk": round(risk,3),
        "reward": round(reward,3),
        "total_rx": st["rx"],
        "success_rate": round(st["success_rate"],3),
        "exp_label": pkt.get("E") or pkt.get("EXP") or "unknown",   # ★ v5.6.10 筆電依此分檔
        "features": {                    # HTML 讀 features.rssi、features.transport 等
            "rssi": raw_rssi,
            "transport": phy_transport,
            "link_class": link_class,
        },
    })
    # ★ v5.1.3: hop_info 只在多跳或 hop 改變時 publish，省 RAM
    last_hop = st.get("_last_pub_hop", 0)
    last_nh  = st.get("_last_pub_nh", -1)
    if hop_count > 1 or hop_count != last_hop or (via_relay or 0) != last_nh:
        mqtt_publish("sensor/node_%02d/hop_info" % src, {
            "dev_id": "node_%02d" % src,
            "src": src,
            "hops": hop_count,
            "nh":   via_relay or src,
            "transport": phy_transport,
            "link_class": link_class,
            "rssi": raw_rssi,
            "risk": round(risk,3),
            "relay_path": pkt.get("_relay_path", []),
        })
        st["_last_pub_hop"] = hop_count
        st["_last_pub_nh"] = via_relay or 0

    icon = "W" if phy_transport=="WIFI" else "L"
    relay_s = ("via N%d " % via_relay) if via_relay else ""
    wl_s  = ("%.2fm" % wl)  if isinstance(wl,(int,float))  else "?"
    d10_s = ("%.2f" % d10)  if isinstance(d10,(int,float)) else "?"
    # ★ v5.2.1: 印 act_recommend (DQN想做) / act_real (leaf真做)
    act_label_rec  = ACTION_LABELS[action]
    act_label_real = ACTION_LABELS[actual_action]
    print("%s N%d %s %sseq=%s wl=%s d10=%s rssi=%d hops=%d risk=%.2f act_dqn=%s act_real=%s lc=%s" % (
        icon, src, pkt.get("semantic_state_name","S0")[:2], relay_s,
        pkt.get("SEQ"), wl_s, d10_s, raw_rssi, hop_count, risk,
        act_label_rec, act_label_real, link_class))


def publish_energy_summary():
    """★ v5.2: 每 60 秒 publish 一次累積能耗 + 各 link class 的封包分布
    給 GCCE 論文的累積能耗曲線用"""
    now = time.ticks_ms()
    payload = {
        "ts": now,
        "tag": EXPERIMENT_TAG,
        "nodes": {},
        "total_mj": 0.0,
    }
    total = 0.0
    for nid in _known_nodes:
        e = _per_node_energy_mj.get(nid, 0.0)
        total += e
        payload["nodes"]["node_%02d" % nid] = {
            "cum_energy_mj": round(e, 2),
            "pkt_by_lc": _per_node_pkt_count.get(nid, {}),
        }
    payload["total_mj"] = round(total, 2)
    mqtt_publish("sensor/sink/energy", payload)
    print("[ENERGY] tag=%s total=%.1f mJ" % (EXPERIMENT_TAG, total))

def publish_fallback_stats():
    """★ v5.5: 每 15 秒 publish fallback 統計給 dashboard"""
    now = time.ticks_ms()
    payload = {
        "ts": now,
        "tag": EXPERIMENT_TAG,
        "nodes": {},
        "summary": {
            "total_in_fb": 0,
            "total_enter": 0,
            "total_recover": 0,
            "total_pending": 0,
            "total_resent": 0,
        },
    }
    for nid in _known_nodes:
        fb = _per_node_fallback.get(nid, {})
        payload["nodes"]["node_%02d" % nid] = dict(fb)
        payload["summary"]["total_in_fb"]   += fb.get("in_fb", 0)
        payload["summary"]["total_enter"]   += fb.get("enter_count", 0)
        payload["summary"]["total_recover"] += fb.get("recover_count", 0)
        payload["summary"]["total_pending"] += fb.get("pending_now", 0)
        payload["summary"]["total_resent"]  += fb.get("resent_total", 0)
    mqtt_publish("sensor/sink/fallback_stats", payload)
    s = payload["summary"]
    if s["total_in_fb"] > 0 or s["total_enter"] > 0:
        print("[FB-STATS] in_fb=%d enter=%d recover=%d pending=%d resent=%d" %
              (s["total_in_fb"], s["total_enter"], s["total_recover"],
               s["total_pending"], s["total_resent"]))

def publish_known_nodes():
    """★ v5.6: 每 30 秒 publish 節點清單給 dashboard"""
    now = time.ticks_ms()
    active, stale = [], []
    nodes_meta = {}
    for nid, info in _known_nodes.items():
        age_ms = time.ticks_diff(now, info.get("last_seen", 0))
        status = info.get("status", "active")
        if status == "active":
            active.append(nid)
        else:
            stale.append(nid)
        nodes_meta["node_%02d" % nid] = {
            "nid": nid,
            "first_seen": info.get("first_seen", 0),
            "last_seen": info.get("last_seen", 0),
            "age_ms": age_ms,
            "total_pkts": info.get("total_pkts", 0),
            "status": status,
        }
    payload = {
        "ts": now,
        "discovery_mode": DISCOVERY_MODE,
        "max_nodes": MAX_NODES,
        "active": sorted(active),
        "stale":  sorted(stale),
        "count": len(_known_nodes),
        "capacity_pct": round(100.0 * len(_known_nodes) / MAX_NODES, 1),
        "nodes_meta": nodes_meta,
        "events": list(_node_events[-20:]),  # 最新 20 筆事件
    }
    mqtt_publish("sensor/sink/known_nodes", payload)
    print("[KNOWN] active=%d stale=%d (cap=%d/%d)" %
          (len(active), len(stale), len(_known_nodes), MAX_NODES))


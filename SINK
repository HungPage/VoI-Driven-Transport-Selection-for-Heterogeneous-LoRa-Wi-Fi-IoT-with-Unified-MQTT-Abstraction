def main():
    global _w1,_b1,_w2,_b2,_tw1,_tb1,_tw2,_tb2,_mqtt_last_active,_frames,_steps
    global _t_last_energy_pub, _t_last_train, _t_last_fallback_pub, _t_last_known_pub

    print("="*62)
    print(" N1 Sink v5.6.9-FINAL  tag=%s" % EXPERIMENT_TAG)
    print(" Discovery=%s  MAX=%d  stale=%ds  remove=%ds" %
          (DISCOVERY_MODE, MAX_NODES, NODE_STALE_MS//1000, NODE_REMOVE_MS//1000))
    print(" DQN: 2 actions (DIRECT/RELAY), train every %dms" % TRAIN_INTERVAL_MS)
    print(" VoI rule (4-to-1):")
    print("   S0→B(LoRa-1x)  S1→C(WiFi-ECO)  S2→A(WiFi-STD)  S3→D(LoRa-2x)")
    print(" Energy: min(target, actual) × (1.3 if RELAY)")
    print("   B=100  C=400  A=600  D=200 mJ (D = 100×2 N-TX diversity)")
    print("="*62)

    wdt = WDT(timeout=8000)
    print("[WDT] enabled, timeout=8s")

    init_wifi()
    init_lora()
    mqtt_connect()
    _mqtt_last_active = time.ticks_ms()

    _w1,_b1 = _init_weights(N_INPUT, N_HIDDEN)
    _w2,_b2 = _init_weights(N_HIDDEN, N_ACTIONS)
    _tw1,_tb1 = _copy_weights(_w1,_b1)
    _tw2,_tb2 = _copy_weights(_w2,_b2)

    try:
        _thread.start_new_thread(mqtt_background_loop, ())
        print("[Thread] MQTT background started")
    except Exception as e:
        print("[Thread] MQTT thread fail:", e)

    print("[Sink] ready")

    t_sum = time.ticks_ms(); t_route = time.ticks_ms()
    t_mqck = time.ticks_ms(); t_ping = time.ticks_ms()
    t_qhint = time.ticks_ms()
    _t_last_energy_pub = time.ticks_ms()
    _t_last_fallback_pub = time.ticks_ms()
    _t_last_known_pub    = time.ticks_ms()
    _t_last_train      = time.ticks_ms()
    _last = time.ticks_ms()

    # ★ v5.4: 新增計時器
    t_led    = time.ticks_ms()
    t_hb     = time.ticks_ms()
    t_tick   = time.ticks_ms()  # ★ v5.6.1: USB keepalive tick
    t_gc     = time.ticks_ms()
    hb_seq   = 0

    while True:
        now = time.ticks_ms()
        wdt.feed()
        try:
            dt = time.ticks_diff(now, _last)
            if dt > 1000:
                print("[Main] loop slow %d ms" % dt)
                gc.collect()
            _last = now

            # ★ v5.4: LED heartbeat (1 秒翻轉一次)
            if time.ticks_diff(now, t_led) > LED_HEARTBEAT_MS:
                led_blink()
                t_led = now

            # ★ v5.4: 5 秒強制 gc.collect() — 避免 fragment 累積
            if time.ticks_diff(now, t_gc) > RAM_GC_INTERVAL_MS:
                gc.collect()
                t_gc = now

            # ★ v5.4: 5 秒強制 print 一行 [HB] — 防 USB suspend → Thonny EOF
            if time.ticks_diff(now, t_hb) > HB_PRINT_INTERVAL_MS:
                hb_seq += 1
                free_now = gc.mem_free()
                print("[HB] seq=%d free_ram=%d eps=%.3f steps=%d replay=%d pending=%d" %
                      (hb_seq, free_now, epsilon, _steps, len(_per_s), len(_pending_exp)))
                t_hb = now

            # ★ v5.6.1: 3 秒印一個 "." 防 Thonny USB CDC suspend
            #   極輕量,不換行,維持 USB 活躍度
            if time.ticks_diff(now, t_tick) > USB_TICK_INTERVAL_MS:
                print(".", end="")
                t_tick = now

            # ★ v5.4: 統一用 ram_check_and_clean(), 多重防線
            free_after, ram_action = ram_check_and_clean()
            if ram_action == "CRITICAL_CLEAR":
                print("[RAM] CRITICAL <%d -> after clear=%d" %
                      (RAM_CRITICAL_BYTES, free_after))
            elif ram_action == "WARN_TRIM":
                pass  # 不每次 print 避免洗版

            if ENABLE_WIFI and not wlan.isconnected():
                wifi_ensure_connected()

            _handle_wifi_accept()
            _handle_lora_rx()

            # 主迴圈只搬經驗到 PER buffer
            if _pending_exp:
                s,a,r,sn,done = _pending_exp.pop(0)
                _per_push(s,a,r,sn,done)
                _frames += 1

            # 訓練 5 分鐘觸發一次
            if time.ticks_diff(now, _t_last_train) > TRAIN_INTERVAL_MS:
                # ★ v5.4: 訓練前先檢查 RAM,不夠就跳過
                if gc.mem_free() < RAM_WARN_BYTES:
                    print("[DQN] skip train (low RAM=%d)" % gc.mem_free())
                else:
                    done_n = _train_dqn_batch(TRAIN_BATCHES_PER_RUN)
                    print("[DQN] periodic train: did %d batches, replay=%d, free_ram=%d" %
                          (done_n, len(_per_s), gc.mem_free()))
                _t_last_train = now

            if time.ticks_diff(now, t_mqck) > 3000:
                if not mqtt_ensure_healthy(): mqtt_reconnect_safe()
                t_mqck = now
            if time.ticks_diff(now, t_ping) > MQTT_PING_INTERVAL:
                mqtt_ping(); t_ping = now

            _mqtt_publish_drain()

            if time.ticks_diff(now, t_route) > ROUTE_INTERVAL:
                broadcast_route_table(); t_route = now
            if time.ticks_diff(now, t_qhint) > QTABLE_BCAST_INTERVAL:
                broadcast_qtable_hint(); t_qhint = now

            # ★ v5.2: 能耗 logger
            if time.ticks_diff(now, _t_last_energy_pub) > ENERGY_PUBLISH_MS:
                publish_energy_summary()
                _t_last_energy_pub = now

            # ★ v5.5: fallback 統計 publish
            if time.ticks_diff(now, _t_last_fallback_pub) > FALLBACK_PUBLISH_MS:
                publish_fallback_stats()
                _t_last_fallback_pub = now

            # ★ v5.6: 動態節點管理 — stale check + known_nodes publish
            _check_stale_nodes()
            if time.ticks_diff(now, _t_last_known_pub) > KNOWN_PUBLISH_MS:
                publish_known_nodes()
                _t_last_known_pub = now

            if time.ticks_diff(now, t_sum) > SUMMARY_INTERVAL:
                print("\n── Sink v5.6.5-MESH tag=%s steps=%d eps=%.3f loss=%.4f nodes=%d/%d ──" %
                      (EXPERIMENT_TAG, _steps, epsilon, _dqn_loss_ema,
                       len(_known_nodes), MAX_NODES))
                for n in _known_nodes:
                    if n not in node_stats: continue   # ★ v5.6 防備
                    s = node_stats[n]
                    age = (time.ticks_diff(now, s.get("last_seen",-1))/1000.0
                           if s.get("last_seen",-1)>0 else -1)
                    print("  N%d rx=%-4d rssi=%d hops=%d nh=%s lc=%s relay=%d age=%.1fs e=%.1fmJ" %
                          (n, s["rx"], s["rssi"], s.get("last_hop_count",1),
                           str(s.get("last_hop_nh")), s.get("last_link_class","B"),
                           s.get("relay_count",0), age,
                           _per_node_energy_mj.get(n, 0.0)))
                print("  replay=%d pending=%d free_ram=%d open_conns=%d\n" %
                      (len(_per_s), len(_pending_exp), gc.mem_free(), len(_open_conns)))
                t_sum = now
                gc.collect()

        except MemoryError as me:
            print("[Main] MemoryError, force GC")
            gc.collect()
            del _mqtt_pub_queue[:]
            time.sleep_ms(100)
        except Exception as e:
            print("[Main] err:", e)
            gc.collect()
            time.sleep_ms(200)
        time.sleep_ms(10)



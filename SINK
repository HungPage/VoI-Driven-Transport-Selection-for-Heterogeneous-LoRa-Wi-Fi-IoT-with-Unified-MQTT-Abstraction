def _unwrap_relay(pkt):
    """
    ★ v5.1: 遞迴拆解 RELAY 包,直到拿到最裡面的 DATA。
    ★ v5.6.2: 同時支援舊格式 (T=RELAY, SRC, SEQ, HOPS, PAYLOAD)
              與壓縮格式 (T=R, S, Q, H, P)
    最多拆 MAX_HOP_COUNT 層,防惡意迴圈。
    回傳 (inner_data_pkt, total_hops, relay_path_list)
    """
    path = []
    cur = pkt
    hops = 0
    for _ in range(MAX_HOP_COUNT + 1):
        if not isinstance(cur, dict): break
        t = cur.get("T")
        # 同時接受 "RELAY"(舊)與 "R"(新壓縮)
        if t != "RELAY" and t != "R": break
        # 取 SRC:舊用 "SRC",新用 "S"
        src = cur.get("SRC", cur.get("S"))
        path.append(src)
        # 取 HOPS:舊用 "HOPS",新用 "H"
        hops_cur = cur.get("HOPS", cur.get("H", hops + 1))
        hops = max(hops, hops_cur)
        # 取 PAYLOAD:舊用 "PAYLOAD",新用 "P"
        inner = cur.get("PAYLOAD", cur.get("P"))
        if inner is None: return None, 0, path
        cur = inner
    return cur, hops, path

def _handle_lora_rx():
    global _lora_consec_err
    if not ENABLE_LORA or not uart.any(): 
        return
    
    try:
        # 讀取所有可用的 UART 資料
        raw = b""
        t0 = time.ticks_ms()
        while uart.any() and time.ticks_diff(time.ticks_ms(), t0) < LORA_READ_TIMEOUT_MS:
            chunk = uart.read(256)
            if chunk: 
                raw += chunk
            else: 
                break
        if not raw: 
            return
        
        raw_str = raw.decode("utf-8", "ignore")
        _lora_consec_err = 0
        
        # 逐行處理 LoRa 接收的資料
        for line in raw_str.split("\n"):
            if "+RCV=" not in line: 
                continue
            
            # 解析 RSSI 值（在 JSON 後面的逗號分隔部分）
            rssi_val = -120
            try:
                tail = line[line.rfind("}")+1:]
                for t in tail.split(","):
                    t = t.strip()
                    if t and t.lstrip("-").isdigit():
                        rssi_val = int(t)
                        break
            except: 
                pass
            
            # 提取 JSON 部分
            si = line.find("{")
            ei = line.rfind("}") + 1
            if si < 0 or ei <= si: 
                continue
            
            try:
                pkt = json.loads(line[si:ei])
            except:
                continue
            
            ptype = pkt.get("T", "")
            src = pkt.get("SRC", 0)
            
            # ★ 註冊節點（任何封包都註冊）
            if src and src != 1:  # 不是 sink 自己
                if _ensure_node_registered(src):
                    # 更新節點統計資訊
                    if src in node_stats:
                        node_stats[src]["rssi"] = rssi_val
                        node_stats[src]["last_seen"] = time.ticks_ms()
            
            # 根據封包類型分發處理
            if ptype in ("HELLO", "RREQ", "RREP", "RERR"):
                aodv_handle_control(pkt, rssi_val)
                
            elif ptype == "RELAY" or ptype == "R":
                # 遞迴拆解 RELAY 包，支援 3 跳
                inner, total_hops, relay_path = _unwrap_relay(pkt)
                if inner and isinstance(inner, dict):
                    inner["_relay_by"] = relay_path[0] if relay_path else None
                    inner["_relay_path"] = relay_path
                    inner["_relay_hops"] = total_hops
                    orig_rssi = pkt.get("ORIG_RSSI", pkt.get("R", rssi_val))
                    process_packet(inner, "LORA", rssi_val,
                                   via_relay=relay_path[0] if relay_path else None,
                                   hop_count=total_hops,
                                   orig_rssi=orig_rssi)
            else:
                # DATA 或其他類型的封包
                process_packet(pkt, "LORA", rssi_val, hop_count=1)
                
    except Exception as e:
        _lora_consec_err += 1
        print("[LoRa] decode err #%d: %s" % (_lora_consec_err, e))
        # 連續錯誤達閾值 → reset 模組
        if _lora_consec_err >= LORA_ERR_RESET_THRESHOLD:
            print("[LoRa] !! resetting module after %d consecutive errors" % _lora_consec_err)
            try:
                init_lora()
                _lora_consec_err = 0
            except Exception as ee:
                print("[LoRa] reset failed:", ee)

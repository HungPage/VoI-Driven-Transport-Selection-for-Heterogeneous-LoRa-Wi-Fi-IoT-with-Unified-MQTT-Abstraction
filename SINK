def _push_node_event(kind, nid, **extra):
    """節點加入/離開事件,記錄給 dashboard"""
    ev = {"ts": time.ticks_ms(), "kind": kind, "nid": nid}
    ev.update(extra)
    _node_events.append(ev)
    while len(_node_events) > 50:   # 保留最新 50 筆
        _node_events.pop(0)

def _ensure_node_registered(nid):
    """★ v5.6 收到封包時呼叫 — 自動註冊新節點"""
    if not isinstance(nid, int) or nid < 2 or nid > 127:
        return False  # 不合法 LoRa address

    now = time.ticks_ms()

    if nid in _known_nodes:
        # 已知節點,更新 last_seen
        _known_nodes[nid]["last_seen"] = now
        _known_nodes[nid]["total_pkts"] += 1
        _ensure_node_stats(nid)  # ★ v5.6 防 stats dict 被清掉的情況
        # 若曾經 stale,標回 active
        if _known_nodes[nid].get("status") == "stale":
            _known_nodes[nid]["status"] = "active"
            _push_node_event("NODE_REJOIN", nid)
            print("[NODE] N%d REJOINED" % nid)
        return True

    # === 新節點 ===
    # 白名單檢查
    if DISCOVERY_MODE == "WHITELIST":
        if NODE_WHITELIST and nid not in NODE_WHITELIST:
            return False

    # 容量檢查
    if len(_known_nodes) >= MAX_NODES:
        # 嘗試踢掉一個 stale 的
        stales = [n for n,d in _known_nodes.items() if d.get("status") == "stale"]
        if stales:
            kicked = stales[0]
            del _known_nodes[kicked]
            _push_node_event("NODE_EVICT", kicked)
            print("[NODE] EVICT N%d to make room" % kicked)
        else:
            print("[WARN] MAX_NODES=%d reached, REJECT N%d" % (MAX_NODES, nid))
            return False

    # 註冊
    _known_nodes[nid] = {
        "first_seen": now,
        "last_seen": now,
        "total_pkts": 1,
        "status": "active",
    }
    _init_node_state(nid)
    _ensure_node_stats(nid)   # ★ v5.6 同步建 stats
    _push_node_event("NODE_JOIN", nid, mode=DISCOVERY_MODE)
    print("[NODE] N%d JOINED  (total=%d/%d, mode=%s)" %
          (nid, len(_known_nodes), MAX_NODES, DISCOVERY_MODE))

    # 警告:接近容量上限
    if len(_known_nodes) >= NODE_WARN_COUNT:
        print("[WARN] node count %d >= %d, approaching MAX_NODES=%d" %
              (len(_known_nodes), NODE_WARN_COUNT, MAX_NODES))
    return True

def _check_stale_nodes():
    """★ v5.6 標記 stale 節點 / 移除超久不見的節點"""
    now = time.ticks_ms()
    to_remove = []
    for nid, info in _known_nodes.items():
        age = time.ticks_diff(now, info.get("last_seen", 0))
        if age > NODE_REMOVE_MS:
            to_remove.append(nid)
        elif age > NODE_STALE_MS and info.get("status") == "active":
            info["status"] = "stale"
            _push_node_event("NODE_STALE", nid, last_seen_ago_s=age//1000)
            print("[NODE] N%d → STALE (no msg %ds)" % (nid, age // 1000))
    for nid in to_remove:
        del _known_nodes[nid]
        _push_node_event("NODE_LEAVE", nid)
        print("[NODE] N%d REMOVED (no msg %ds)" % (nid, NODE_REMOVE_MS // 1000))
        # 注意:per-node dict 故意保留,讓 stats 不丟失;若 RAM 緊再清


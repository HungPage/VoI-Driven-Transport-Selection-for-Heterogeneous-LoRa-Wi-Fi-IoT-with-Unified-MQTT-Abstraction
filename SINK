def _send_tcp_ack(conn, pkt=None):
    ack = {"ok":1,"node":1}
    if pkt:
        ack["type"] = pkt.get("T","DATA") or "DATA"
        ack["seq"]  = pkt.get("SEQ")
        ack["src"]  = pkt.get("SRC",0)
    try: _send_all(conn, _json_frame(ack)); return True
    except Exception as e: print("[TCP] ack fail:", e); return False

_tcp_last_rebind = 0
TCP_REBIND_COOLDOWN = 30_000   # 兩次 rebind 至少間隔 30 秒

def _ensure_tcp_server():
    """★ v5.1.5: 只在『真的有錯』時才 rebind，加冷卻時間"""
    global server_sock, _open_conns, _tcp_last_rebind
    if server_sock is not None:
        return  # 還活著就什麼都不做
    now = time.ticks_ms()
    if time.ticks_diff(now, _tcp_last_rebind) < TCP_REBIND_COOLDOWN:
        return  # 冷卻中
    try:
        print("[TCP] rebinding server socket...")
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        s.bind(("0.0.0.0", TCP_DATA_PORT))
        s.listen(5)
        s.setblocking(False)
        server_sock = s
        _open_conns = []
        _tcp_last_rebind = now
        print("[TCP] rebound :%d OK" % TCP_DATA_PORT)
    except Exception as e:
        print("[TCP] rebind fail:", e)
        _tcp_last_rebind = now   # 即使失敗也設冷卻，不要瘋狂重試

def _handle_wifi_accept():
    global _open_conns, server_sock
    _ensure_tcp_server()
    if not server_sock: return
    _open_conns = [c for c in _open_conns if c is not None]
    if len(_open_conns) > 4:
        for c in _open_conns[:2]:
            try: c.close()
            except: pass
        _open_conns = _open_conns[2:]
    try:
        import select
        readable,_,_ = select.select([server_sock], [], [], 0)
        if not readable: return
        conn, addr = server_sock.accept()
        _open_conns.append(conn)
    except OSError as e:
        # ★ v5.1.5: errno 11 = EAGAIN (沒人連)；其他才算真錯
        if e.args and e.args[0] == 11:
            return
        # 真的有錯誤才 mark dead
        print("[TCP] accept err, will rebind:", e)
        try: server_sock.close()
        except: pass
        server_sock = None
        return
    except Exception as e:
        print("[TCP] select err, will rebind:", e)
        try: server_sock.close()
        except: pass
        server_sock = None
        return

    try:
        conn.settimeout(TCP_TIMEOUT_S)
        wrap = _recv_json_frame(conn, timeout_s=TCP_ACK_TIMEOUT_S)
        if wrap and "data" in wrap:
            pkt = wrap["data"]
            process_packet(pkt, "WIFI", raw_rssi=_wlan_rssi_cached())
            _send_tcp_ack(conn, pkt)
        else:
            _send_tcp_ack(conn, None)
    except Exception as e:
        try: _send_tcp_ack(conn, None)
        except: pass
    finally:
        try:
            conn.close()
            if conn in _open_conns: _open_conns.remove(conn)
        except: pass


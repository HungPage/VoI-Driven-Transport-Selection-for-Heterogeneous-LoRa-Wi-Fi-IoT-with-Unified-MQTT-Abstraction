def ram_check_and_clean():
    """★ v5.4 多重 RAM 防線
       回傳 (free_bytes, action_taken_str)"""
    free = gc.mem_free()
    action = "ok"

    if free < RAM_CRITICAL_BYTES:
        # 緊急:清空一切非必要 buffer
        action = "CRITICAL_CLEAR"
        global _mqtt_pub_queue, _aodv_events, _lora_pkt_dedup, _pending_exp
        _mqtt_pub_queue = []
        _aodv_events    = []
        _lora_pkt_dedup = {}
        # 經驗池保留一半
        if len(_pending_exp) > 4:
            _pending_exp = _pending_exp[-4:]
        gc.collect()

    elif free < RAM_WARN_BYTES:
        # 溫和:重建 dict / list 真正釋放(不是 del slice)
        action = "WARN_TRIM"
        if len(_mqtt_pub_queue) > MQTT_QUEUE_HARD_CAP // 2:
            _mqtt_pub_queue[:] = _mqtt_pub_queue[-(MQTT_QUEUE_HARD_CAP // 2):]
        if len(_aodv_events) > AODV_EVENTS_HARD_CAP // 2:
            _aodv_events[:] = _aodv_events[-(AODV_EVENTS_HARD_CAP // 2):]
        if len(_lora_pkt_dedup) > LORA_DEDUP_HARD_CAP // 2:
            # 重建 dict 真正釋放(避免 fragment)
            items = sorted(_lora_pkt_dedup.items(), key=lambda x: -x[1])[:LORA_DEDUP_HARD_CAP // 2]
            globals()['_lora_pkt_dedup'] = dict(items)
        if len(_pending_exp) > PENDING_EXP_HARD_CAP // 2:
            _pending_exp[:] = _pending_exp[-(PENDING_EXP_HARD_CAP // 2):]
        gc.collect()

    return gc.mem_free(), action

def _close_sock(s):
    if s:
        try: s.close()
        except: pass

def _json_frame(obj):
    return (json.dumps(obj) + "\n").encode()

def _send_all(sock, data):
    sent = 0
    while sent < len(data):
        n = sock.send(data[sent:])
        if not n: raise OSError("send failed")
        sent += n

def _recv_json_frame(sock, timeout_s=TCP_ACK_TIMEOUT_S, max_bytes=TCP_MAX_FRAME):
    sock.settimeout(timeout_s)
    buf = b""
    while len(buf) < max_bytes:
        try:
            chunk = sock.recv(TCP_RECV_CHUNK)
        except OSError:
            break
        if not chunk: break
        buf += chunk
        if b"\n" in buf:
            line = buf.split(b"\n", 1)[0]
            if not line: return None
            try: return json.loads(line.decode().strip())
            except: return None
    if buf:
        try: return json.loads(buf.decode().strip())
        except: return None
    return None


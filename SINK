#  §7  AODV
# ─────────────────────────────────────────────────────────────

def voi_risk(wl, d10):
    try:
        z = AODV_BETA[0] + AODV_BETA[1]*(wl or 0) + AODV_BETA[2]*(d10 or 0)
        return _sigmoid(z)
    except:
        return 0.0

def _route_cost(rssi, hops, risk):
    nr = 1.0 - _clip((rssi + 120) / 90.0, 0.0, 1.0)
    nh = _clip(hops / 5.0, 0.0, 1.0)
    return AODV_W[0]*nr + AODV_W[1]*nh + AODV_W[2]*risk

def _aodv_seq_next():
    global _aodv_seq
    _aodv_seq = (_aodv_seq + 1) % 65536
    return _aodv_seq

def _aodv_update_route(dst, nh, hops, rssi, seq, risk=0.0):
    # ★ v5.2.2 FIX: RSSI 合理性過濾
    if rssi < -120 or rssi > -10:
        return False
    now = time.ticks_ms()
    cost = _route_cost(rssi, hops, risk)
    if dst in _routing:
        ex = _routing[dst]
        ex_cost = _route_cost(ex["rssi"], ex["hops"], ex["risk"])
        if seq <= ex.get("seq", -1) and cost >= ex_cost:
            return False
    _routing[dst] = dict(nh=nh, hops=hops, rssi=rssi,
                         seq=seq, risk=risk, cost=cost, age=now)
    print("  [AODV] N%d via N%d hops=%d rssi=%d risk=%.2f cost=%.2f" %
          (dst, nh, hops, rssi, risk, cost))
    _push_aodv_event("ROUTE_UPDATE", dst, nh, hops, rssi, risk)
    return True

def _aodv_dedup(src, ptype, seq):
    key = (src, ptype, seq)
    now = time.ticks_ms()
    if key in _rreq_seen and time.ticks_diff(now, _rreq_seen[key]) < 10000:
        return True
    _rreq_seen[key] = now
    if len(_rreq_seen) > 128:
        items = sorted(_rreq_seen.items(), key=lambda x: x[1])
        for k,_ in items[:64]:
            del _rreq_seen[k]
    return False

def _push_aodv_event(kind, dst, nh=None, hops=None, rssi=None, risk=None):
    ev = {"kind":kind,"dst":dst,"ts":time.ticks_ms()}
    if nh is not None:   ev["nh"]=nh
    if hops is not None: ev["hops"]=hops
    if rssi is not None: ev["rssi"]=rssi
    if risk is not None: ev["risk"]=round(risk,3)
    _aodv_events.append(ev)
    if len(_aodv_events) > 5:
        del _aodv_events[0:len(_aodv_events)-30]
    # ★ v5.1.4: 不再每筆即時 publish，改由 route_table 那條 topic 一起帶
    # 只有重要事件 (RERR / EXPIRE) 才即時 publish
    if kind in ("RERR", "EXPIRE"):
        try:
            mqtt_publish("sensor/sink/aodv_event", ev)
        except:
            pass

def aodv_handle_control(pkt, rssi):
    ptype = pkt.get("T","")
    src   = pkt.get("SRC", 0)
    seq   = pkt.get("SEQ", 0)
    
    # ★ 新增：收到任何控制封包時註冊節點
    if src and src != 1:  # 不是 sink 自己
        _ensure_node_registered(src)
        # 更新 RSSI 資訊
        if src in node_stats:
            node_stats[src]["rssi"] = rssi
            node_stats[src]["last_seen"] = time.ticks_ms()
    
    if _aodv_dedup(src, ptype, seq): return

    if ptype == "HELLO":
        _aodv_update_route(src, src, 1, rssi, seq, risk=pkt.get("RISK",0.0))

    elif ptype == "RREQ":
        orig = pkt.get("ORIG", src)
        dst  = pkt.get("DST", 1)
        hops = pkt.get("HOPS", 0) + 1
        _aodv_update_route(orig, src, hops, rssi, seq, risk=pkt.get("RISK",0.0))
        _push_aodv_event("RREQ_RX", dst, nh=src, hops=hops, rssi=rssi)
        if dst == 1:
            rrep = {"T":"RREP","SRC":1,"DST":orig,"ORIG_DST":dst,
                    "HOPS":0,"RSSI":rssi,"SEQ":_aodv_seq_next()}
            lora_unicast(src, rrep)
            _push_aodv_event("RREP_TX", orig, nh=src, hops=0)

    elif ptype == "RREP":
        orig = pkt.get("SRC", 0)
        hops = pkt.get("HOPS", 0) + 1
        _aodv_update_route(orig, src, hops, rssi, seq)
        _push_aodv_event("RREP_RX", orig, nh=src, hops=hops, rssi=rssi)

    elif ptype == "RERR":
        dead = pkt.get("DEAD", pkt.get("BROKEN", 0))
        if dead in _routing:
            del _routing[dead]
            _push_aodv_event("RERR", dead)

def prune_expired_routes():
    now = time.ticks_ms()
    gone = []
    for dst, r in _routing.items():
        if time.ticks_diff(now, r.get("age", now)) > AODV_ROUTE_EXPIRE:
            gone.append(dst)
    for d in gone:
        del _routing[d]
        _push_aodv_event("EXPIRE", d)

def build_route_table_snapshot():
    prune_expired_routes()
    rt = {}
    for dst, r in _routing.items():
        # ★ v5.2: 路由 entry 帶 transport 建議（VoI 硬規則）+ relay 決策（DQN）
        dec = _per_node_best_decision.get(dst, {})
        rt[str(dst)] = {
            "nh":   r["nh"],
            "hops": r["hops"],
            "rssi": r["rssi"],
            "risk": round(r.get("risk",0.0), 3),
            "cost": round(r.get("cost",0.0), 3),
            # ★ v5.2 取代原本的 lc：給 leaf 看的「平時/緊急」transport + 是否 relay
            "tx_common": dec.get("transport_common", "LORA"),
            "tx_alert":  dec.get("transport_alert",  "WIFI"),
            "dec_common": dec.get("common", "DIRECT"),
            "dec_alert":  dec.get("alert",  "DIRECT"),
            # ★ v5.2 預測式 AODV：高風險旗標
            "high_risk": 1 if r.get("risk", 0.0) > AODV_RISK_THRESHOLD else 0,
        }
    return rt

def broadcast_route_table():
    """★ v5.2: ROUTE 廣播改為帶 transport + decision 雙建議"""
    global _route_seq
    _route_seq = (_route_seq + 1) % 65536
    rt = build_route_table_snapshot()
    # ★ EXPERIMENT_TAG 影響：四策略基準時，把 transport 建議鎖死
    if EXPERIMENT_TAG == "ALWAYS_LORA":
        for k in rt: rt[k]["tx_common"] = "LORA"; rt[k]["tx_alert"] = "LORA"
    elif EXPERIMENT_TAG == "ALWAYS_WIFI":
        for k in rt: rt[k]["tx_common"] = "WIFI"; rt[k]["tx_alert"] = "WIFI"
    elif EXPERIMENT_TAG == "PERIODIC":
        # 由 leaf 端按時間表自行切換，sink 不強制
        pass
    pkt = {"T":"ROUTE","SRC":1,"SEQ":_route_seq,
           "EPS":round(epsilon,3),"TAG":EXPERIMENT_TAG,"RT":rt}
    lora_broadcast(pkt)
    high_risk_n = sum(1 for v in rt.values() if v.get("high_risk", 0))
    print("[AODV] ROUTE seq=%d entries=%d high_risk=%d tag=%s" %
          (_route_seq, len(rt), high_risk_n, EXPERIMENT_TAG))

def broadcast_qtable_hint():
    """★ v5.2: QHINT 廣播 DIRECT/RELAY 偏好 + transport 建議"""
    global _qtable_seq
    update_node_best_decision()
    _qtable_seq = (_qtable_seq + 1) % 65536
    hints = {}
    for nid in _known_nodes:
        # 對 S0 / S2 兩個極端 VoI 算 Q 值給 leaf 參考
        q_per_voi = {}
        for voi in ("S0", "S2"):
            st = _to_state(nid, 1, voi)

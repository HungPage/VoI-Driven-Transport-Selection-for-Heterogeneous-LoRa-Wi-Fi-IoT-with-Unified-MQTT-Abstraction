def _sigmoid(x):
    if x >  20: return 1.0
    if x < -20: return 0.0
    return 1.0 / (1.0 + math.exp(-x))

def _clip(x, lo, hi):
    return lo if x < lo else (hi if x > hi else x)


def normalize_voi_short(state_str):
    """Normalize semantic state names from leaf/model to sink short form S0/S1/S2/S3.
    This is intentionally minimal and does not alter the original routing/DQN logic.
    """
    if not state_str:
        return "S0"
    s = str(state_str).strip()
    mapping = {
        "S0_STABLE": "S0",
        "S1_RISING": "S1",
        "S2_FLOOD": "S2",
        "S3_RECEDING": "S3",
        "S0": "S0",
        "S1": "S1",
        "S2": "S2",
        "S3": "S3",
    }
    return mapping.get(s, s[:2] if len(s) >= 2 else "S0")


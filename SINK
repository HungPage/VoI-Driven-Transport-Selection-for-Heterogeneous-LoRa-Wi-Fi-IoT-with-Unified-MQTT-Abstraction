def mqtt_publish(topic, value):
    """★ v5.2: 用 MQTT_QUEUE_HARD_CAP 統一管理 ring buffer 上限"""
    try:
        _mqtt_pub_queue.append((topic, json.dumps(value)))
        # 超過硬上限，丟最舊的
        while len(_mqtt_pub_queue) > MQTT_QUEUE_HARD_CAP:
            _mqtt_pub_queue.pop(0)
    except Exception as e:
        print("[MQTT] enqueue err:", e)

def _mqtt_publish_drain():
    """主線程呼叫：把 queue 裡的訊息一次送出，獨佔 _mqtt socket
       ★ v5.1.7: 加 timeout 保護，避免 socket hang 把整個主迴圈拖死"""
    global _mqtt, _mqtt_last_active
    if _mqtt is None: return
    n = 0
    t0 = time.ticks_ms()
    while _mqtt_pub_queue and n < 5:   # 一次最多 10 筆
        # 超過 500ms 就放棄這輪，下次再來
        if time.ticks_diff(time.ticks_ms(), t0) > 500:
            print("[MQTT] drain timeout, deferring %d msgs" % len(_mqtt_pub_queue))
            break
        topic, payload = _mqtt_pub_queue.pop(0)
        try:
            _mqtt.publish(topic.encode(), payload.encode())
            _mqtt_last_active = time.ticks_ms()
            n += 1
        except Exception as e:
            print("[MQTT] pub err:", e)
            try: _mqtt.disconnect()
            except: pass
            _mqtt = None
            break


def mqtt_background_loop():
    """Thread A：心跳 + 路由表 + DQN 統計 publish (★ v5.1.2: 只 enqueue，不直接 publish)"""
    t_hb = 0; t_rt = 0; t_dq = 0
    consecutive_err = 0
    while True:
        try:
            now = time.ticks_ms()

            if time.ticks_diff(now, t_hb) > HEARTBEAT_PUBLISH_MS:
                for n in _known_nodes:
                    s = node_stats.get(n, {})
                    # ★ v5.1.3: 從沒收過資料 / 太老的節點不發心跳，避免儀表板假資料
                    if s.get("rx", 0) == 0:
                        continue
                    last = s.get("last_seen", -1)
                    if last <= 0 or time.ticks_diff(now, last) > 300_000:  # 5 分鐘沒收到
                        continue
                    mqtt_publish("sensor/node_%02d/heartbeat" % n, {
                        "dev_id": "node_%02d" % n,
                        "total_rx": s.get("rx",0),
                        "rssi": s.get("rssi",-120),
                        "success_rate": round(s.get("success_rate",0.0),3),
                        "last_link_class": s.get("last_link_class","B"),
                        "last_hop_count": s.get("last_hop_count",1),
                        "last_hop_nh":    s.get("last_hop_nh"),
                        "relay_count": s.get("relay_count",0),
                        "features": {
                            "rssi": s.get("rssi",-120),
                            "link_class": s.get("last_link_class","B"),
                        },
                    })
                t_hb = now

            if time.ticks_diff(now, t_rt) > ROUTE_PUBLISH_MS:
                rt = build_route_table_snapshot()
                mqtt_publish("sensor/sink/route_table", {
                    "ts": now, "tag": EXPERIMENT_TAG, "rt": rt,
                    "events": list(_aodv_events[-20:]),
                })
                t_rt = now

            if time.ticks_diff(now, t_dq) > DQN_PUBLISH_MS:
                total_rec = sum(_action_count_recommended) or 1
                total_act = sum(_action_count_actual) or 1
                mqtt_publish("sensor/sink/dqn_state", {
                    "ts": now,
                    "tag": EXPERIMENT_TAG,
                    "epsilon": round(epsilon,3),
                    "steps": _steps,
                    "loss_ema": round(_dqn_loss_ema,4),
                    "avg_q_ema": round(_avg_q_ema,4),
                    "replay_size": len(_per_s),
                    "pending_size": len(_pending_exp),
                    # ★ v5.2.1: 同時送 actual (leaf 真做) 和 recommended (DQN 想做)
                    "action_dist": [round(_action_count_actual[i]/total_act, 3) for i in range(N_ACTIONS)],
                    "action_dist_recommended": [round(_action_count_recommended[i]/total_rec, 3) for i in range(N_ACTIONS)],
                    "action_labels": ACTION_LABELS,
                    "action_count_actual": list(_action_count_actual),
                    "action_count_recommended": list(_action_count_recommended),
                    "per_node_best_decision": _per_node_best_decision,
                })
                t_dq = now

            time.sleep_ms(200)
            consecutive_err = 0
        except Exception as e:
            consecutive_err += 1
            print("[HB] err #%d:" % consecutive_err, e)
            if consecutive_err > 10:
                print("[HB] too many errors, restarting in 10s...")
                time.sleep(10)
                consecutive_err = 0
            else:
                time.sleep(1)

